rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Classroom space rules - fully opened to prevent any list/write permission blockages
    match /classrooms/{document=**} {
      allow read, write: if true;
    }

    // Test connection path
    match /test/{document=**} {
      allow read, write: if true;
    }
  }
}

