rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Classroom space rules
    match /classrooms/{classCode} {
      allow read, write: if classCode is string && classCode != "";

      // Allow all reads and writes under any student subdocument safely
      match /students/{studentId} {
        allow read, write: if classCode is string && studentId is string;
      }
    }
  }
}
